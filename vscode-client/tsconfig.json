{
    "compilerOptions": {
        "target": "es2024",
        "lib": ["es2024"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": ["node"],
        "sourceMap": true,
        "strict": true,
        "outDir": "./lib",
        "rootDir": "./src",
        "composite": true
